# ============================================================
# QUERIES
# ============================================================


# 1) Display all names of employees whose name starts with 'A' and has at least 3 characters

select first_name
from emp
where lower(first_name) like 'a%'
and length(first_name) >= 3;

# OUTPUT:
Alan
Adam
Alice


# 2) Display departments located in Dallas, New York and Chicago

select dept_name
from departments
where lower(location) in ('dallas','new york','chicago');

# OUTPUT:
ACCOUNTING
RESEARCH
SALES


# 3) Employees working as clerk, salesman or analyst 
#    and earning salary >= 3000

select first_name, job, salary
from emp
where lower(job) in ('clerk','salesman','analyst')
and salary >= 3000;

# OUTPUT:
FIRST_NAME   JOB       SALARY
Alan         ANALYST    3000


# 4) Display employees who are not managers

select first_name, job
from emp
where lower(job) != 'manager';

# OUTPUT:
James   CLERK
Scott   SALESMAN
Adam    CLERK
Alan    ANALYST
Alice   CLERK
George  CLERK
Diana   SALESMAN
Bob     CLERK


# 5) Employee who earns highest salary

select first_name, job, salary
from emp
where salary = (select max(salary) from emp);

# OUTPUT:
John   MANAGER   5000


# 6) Employee who earns highest salary among clerks

select emp_no, first_name, job, salary
from emp
where salary = (
    select max(salary)
    from emp
    where lower(job) = 'clerk'
);

# OUTPUT:
7566   James   CLERK   2450


# 7) Clerks who earn more than Bob and less than James

select first_name, salary
from emp
where lower(job) = 'clerk'
and salary > (select salary from emp where lower(first_name) = 'bob')
and salary < (select salary from emp where lower(first_name) = 'james');

# OUTPUT:
FIRST_NAME   SALARY
Adam         1300
Alice        1600
George       1100

# 8) Display the names of the employees who earn the highest salary in their respective departments

select first_name, deptno, salary
from emp e1
where salary = (
    select max(salary)
    from emp e2
    where e2.deptno = e1.deptno
);

# OUTPUT:
FIRST_NAME   DEPTNO   SALARY
John         10       5000
Alan         20       3000
Diana        30       2950
George       40       1100


# 9) Display employees who are working in the same department as their manager

select e.first_name as employee_name, e.deptno, m.first_name as manager_name
from emp e
join emp m on e.manager_id = m.emp_no
where e.deptno = m.deptno;

# OUTPUT:
EMPLOYEE_NAME   DEPTNO   MANAGER_NAME
James           20       John
Scott           30       John
Adam            30       John
Alan            20       James
