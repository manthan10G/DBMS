2.Add Two Numbers
CREATE OR REPLACE FUNCTION Add_Num(a IN INT, b IN INT)
RETURN INT
IS
c INT;
BEGIN
c := a + b;
RETURN c;
END;
/
SELECT Add_Num(12, 14) FROM dual;
OUTPUT:
ADD_NUM(12,14)
26


3.Square of a Number
CREATE OR REPLACE FUNCTION Sqrt_Num(a IN INT)
RETURN INT
IS
c INT;
BEGIN
c := a * a;
RETURN c;
END;
/
SELECT Sqrt_Num(12) FROM dual;
#OUTPUT:
SQRT_NUM(12)
144
